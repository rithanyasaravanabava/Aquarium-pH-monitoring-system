import random
ph = round(random.uniform(6.0, 8.5), 1)
if 6.8 <= ph <= 8.0:
    status = "SAFE"
else:
    status = " UNSAFE"
print("AQUARIUM pH MONITOR")
print("*" * 25)
print(f"pH: {ph}")
print(f"Status: {status}")

if status == " UNSAFE":
    if ph < 6.8:
        print(" RECOMMENDATION: Add pH UP chemicals")
    else:  
        print(" RECOMMENDATION: Add pH DOWN chemicals or change water")
else:
    print(" RECOMMENDATION: Maintain current conditions")
    
print("*" * 25)
